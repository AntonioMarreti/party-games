# Disable directory browsing
Options -Indexes

# Block access to hidden files (.git, .env, etc)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to sensitive config files
<FilesMatch "^(config\.php|composer\.json|package\.json|package-lock\.json|README\.md|LICENSE|task\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block ad-hoc debug/test scripts from being served
<FilesMatch "^test_.*\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Force HTTPS. The second condition avoids a redirect loop when TLS is
# terminated by an upstream proxy (e.g. Cloudflare) that talks HTTP to the origin.
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    # Telegram Mini Apps are framed by Telegram clients, so framing is restricted
    # to self and Telegram rather than denied outright.
    Header always set Content-Security-Policy "frame-ancestors 'self' https://*.telegram.org"
</IfModule>
